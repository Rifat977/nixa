# Nixa Django – environment variables template
# Copy to .env and set your values: cp .env.example .env

# --- Required in production ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# --- Debug: True for local dev, False for production ---
DJANGO_DEBUG=True

# --- Email (optional) ---
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# --- Optional: PostgreSQL ---
# DATABASE_URL=postgres://user:password@localhost:5432/nixa
